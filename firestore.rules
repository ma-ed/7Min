rules_version = '2';

// v1: Bewusst vollständig offen – kein Firebase Auth, kein Passwortschutz.
// Jeder der eine UID kennt kann die Daten lesen und schreiben.
// Vor einer öffentlichen Freigabe mit echten Nutzern unbedingt auf
// authentifizierungsbasierte Regeln upgraden.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
